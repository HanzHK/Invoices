@using Invoices.Blazor.Components.Infrastructure.Localization
@using Invoices.Shared.Models.Invoice
@inherits LocalizationComponentBase

<MudTable Items="@Items"
          Hover="true"
          Dense="false"
          Bordered="true"
          Striped="true"
          Elevation="1"
          T="InvoiceGetDto"
          FixedHeader="true">
    <ColGroup>
        <col style="width: 8%;" />
        <col style="width: 12%;" />
        <col style="width: 12%;" />
        <col style="width: 10%;" />
        <col style="width: 10%;" />
        <col style="width: 18%;" />
        <col style="width: 8%;" />
        <col style="width: 6%;" />
        <col style="width: 16%;" />
    </ColGroup>
    <HeaderContent>
        <MudTh><MudTableSortLabel T="InvoiceGetDto" SortBy="new Func<InvoiceGetDto, object>(x => x.InvoiceNumber)">@T("InvoiceNumber")</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="InvoiceGetDto" SortBy="new Func<InvoiceGetDto, object>(x => x.Seller.Name)">@T("Seller")</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="InvoiceGetDto" SortBy="new Func<InvoiceGetDto, object>(x => x.Buyer.Name)">@T("Buyer")</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="InvoiceGetDto" SortBy="new Func<InvoiceGetDto, object>(x => x.Issued)">@T("IssuedDate")</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="InvoiceGetDto" SortBy="new Func<InvoiceGetDto, object>(x => x.DueDate)">@T("DueDate")</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="InvoiceGetDto" SortBy="new Func<InvoiceGetDto, object>(x => x.Product)">@T("Product")</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="InvoiceGetDto" SortBy="new Func<InvoiceGetDto, object>(x => x.Price)">@T("Price")</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="InvoiceGetDto" SortBy="new Func<InvoiceGetDto, object>(x => x.Vat)">@T("Vat")</MudTableSortLabel></MudTh>
        <MudTh>@T("Actions")</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.InvoiceNumber</MudTd>
        <MudTd>@context.Seller.Name</MudTd>
        <MudTd>@context.Buyer.Name</MudTd>
        <MudTd>@context.Issued.ToString("dd.MM.yyyy")</MudTd>
        <MudTd>@context.DueDate.ToString("dd.MM.yyyy")</MudTd>
        <MudTd>@context.Product</MudTd>
        <MudTd>@context.Price.ToString("N2", CzechCulture) Kč</MudTd>
        <MudTd>@context.Vat %</MudTd>
        <MudTd></MudTd>
    </RowTemplate>
</MudTable>