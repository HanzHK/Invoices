@using Invoices.Blazor.Components.Infrastructure.Localization
@using Invoices.Blazor.InputHandlers
@using Invoices.Shared.Models.Person
@inherits LocalizationComponentBase
<MudForm @ref="form" Model="Invoice">
    <MudGrid Spacing="8">
            <MudItem xs="12" md="12">
        <MudTextField Value="@Invoice.InvoiceNumber"
                      ValueChanged="@((string v) =>
                                          Invoice.InvoiceNumber = NumbersInputHandler.Handle(v, new[] { 50 }))"
                      Label="@T("InvoiceNumber")"
                      Required="true"
                      Immediate="true"
                          Variant="Variant.Outlined"
                      InputType="InputType.Number"
                      Validation="@Validator.ValidateAll(
                                          Validator.Required("InvoiceNumber"),
                                          Validator.MaxLength("InvoiceNumber", 50)
                                    )" />
            </MudItem>

        <MudItem xs="12" md="6">
            <MudAutocomplete T="PersonDto"
                             Label="@T("Seller")"
                             Variant="Variant.Outlined"
                             SearchFunc="SearchPersons"
                             ToStringFunc="@(p => p == null ? "" : $"{p.Name} ({p.IdentificationNumber})")"
                             ValueChanged="@((PersonDto p) => Invoice.Seller.Id = p.PersonId)"
                             Required="true" />

        </MudItem>

        <MudItem xs="12" md="6">
            <MudAutocomplete T="PersonDto"
                             Label="@T("Buyer")"
                             Variant="Variant.Outlined"
                             SearchFunc="SearchPersons"
                             ToStringFunc="@(p => p == null ? "" : $"{p.Name} ({p.IdentificationNumber})")"
                             ValueChanged="@((PersonDto p) => Invoice.Buyer.Id = p.PersonId)"
                             Required="true" />
        </MudItem>

        <MudItem xs="12" md="6">

        <MudDatePicker Label="@T("IssuedDate")"
                       Date="@(Invoice.Issued.ToDateTime(TimeOnly.MinValue))"
                       DateChanged="@((DateTime? d) => Invoice.Issued = DateOnly.FromDateTime(d ?? DateTime.Today))"
                           Variant="Variant.Outlined"
                       Required="true" />

            </MudItem>
       
         <MudItem xs="12" md="6">

        <MudDatePicker Label="@T("DueDate")"
                       Date="@(Invoice.DueDate.ToDateTime(TimeOnly.MinValue))"
                       DateChanged="@((DateTime? d) => Invoice.DueDate = DateOnly.FromDateTime(d ?? DateTime.Today))"
                           Variant="Variant.Outlined"
                       Required="true" />
        </MudItem>

         <MudItem xs="12" md="12">

        <MudTextField Value="@Invoice.Product"
                      ValueChanged="@((string v) =>
                            Invoice.Product = TextInputHandler.Handle(v, new TextInputOptions {
                                Trim = false,
                                CollapseWhitespace = false,
                                Casing = TextCasing.None,
                                MaxLength = 200,
                                RemoveDigits = false
                            }))"
                      Label="@T("Product")"
                      Required="true"
                      Immediate="true"
                      InputType="InputType.Text"
                      Variant="Variant.Outlined"
                      Validation="@Validator.ValidateAll(
                                                                Validator.Required("Product"),
                                                                Validator.MaxLength("Product", 200)
                                                          )" />
        </MudItem>

        <MudItem xs="12" md="6">
        <MudNumericField T="decimal"
                 @bind-Value="Invoice.Price"
                 Label="@T("Price")"
                 Required="true"
                 Min="0"
                 Max="999999999" 
                 Format="N2"
                 Culture="@CzechCulture"
                 Adornment="Adornment.End"
                 AdornmentText="Kč"
                 Variant="Variant.Outlined"/>

        </MudItem>

        <MudItem xs="12" md="6">

        <MudNumericField T="decimal"
                         @bind-Value="Invoice.Vat"
                         Label="@T("Vat")"
                         Required="true"
                         Min="0"
                         Max="100"
                         Format="N2"
                         Culture="@CzechCulture"
                         Adornment="Adornment.End"
                         AdornmentText="%"
                         Variant="Variant.Outlined" />
        </MudItem>

         <MudItem xs="12" md="12">

                <MudTextField Value="@Invoice.Note"
                      ValueChanged="@((string v) =>
                            Invoice.Note = TextInputHandler.Handle(v, new TextInputOptions {
                                Trim = false,
                                CollapseWhitespace = false,
                                Casing = TextCasing.None,
                                MaxLength = 500,
                                RemoveDigits = false
                            }))"
                      Label="@T("Note")"
                      Required="false"
                      Immediate="true"
                      FullWidth="true"
                              Lines="4"
                      InputType="InputType.Text"
                          Variant="Variant.Outlined"
                      Validation="@Validator.ValidateAll( Validator.MaxLength("Note", 500))" />
            </MudItem>

        <MudItem xs="12" md="12">

        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                           FullWidth="true"
                   OnClick="Submit">
            @T("Save")
        </MudButton>
        </MudItem>

        </MudGrid>
</MudForm>
