@using Invoices.Blazor.Components.Infrastructure.Localization
@using Invoices.Blazor.Components.Person.ActionButtons
@inherits LocalizationComponentBase

<MudTable Items="@Items"
          Hover="true"
          OnRowClick="@((TableRowClickEventArgs<PersonDto> args) => Nav.NavigateTo($"/subjects/detail/{args.Item.PersonId}"))"
          RowClass="cursor-pointer"
          Dense="false"
          Bordered="true"
          Striped="true"
          Elevation="1"
          T="PersonDto"
          FixedHeader="true"
          HeaderClass="mud-theme-primary">
    <ColGroup>
        <col style="width: 20%;" />
        <col style="width: 30%;" />
        <col style="width: 20%;" />
    </ColGroup>
    <HeaderContent>
        <MudTh><MudTableSortLabel T="PersonDto" SortBy="new Func<PersonDto, object>(x => x.IdentificationNumber)"><strong>@T("IdentificationNumber")</strong></MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="PersonDto" SortBy="new Func<PersonDto, object>(x => x.Name)"><strong>@T("Name")</strong></MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="PersonDto" SortBy="new Func<PersonDto, object>(x => x.City)"><strong>@T("City")</strong></MudTableSortLabel></MudTh>
        <MudTh><strong>@T("Actions")</strong></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.IdentificationNumber</MudTd>
        <MudTd>@context.Name</MudTd>
        <MudTd>@context.City</MudTd>
        <MudTd>
            <PersonActionButtons PersonModel="@context"
                                 OnDelete="HandleDelete" />
        </MudTd>
    </RowTemplate>
</MudTable>