@using Invoices.Blazor.Components.Infrastructure.Localization
@using Invoices.Blazor.Components.Infrastructure.Sections
@inherits UnifiedSectionBase
<MudCard Class="detail-card" Elevation="2" Style="height: 100%">
    <MudCardHeader Class="detail-header" Style="padding: 8px 16px;">
        <CardHeaderContent>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.StickyNote2" Color="Color.Primary" />
                <MudText Typo="Typo.h6">@T("Note")</MudText>
            </MudStack>
        </CardHeaderContent>
    </MudCardHeader>

    <MudCardContent>
        <MudGrid GutterSize="16px">
            <MudItem xs="12" sm="@ColumnSize">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudText Typo="Typo.body1" Class="detail-value">@Person.Note</MudText>
                    </MudStack>
            </MudItem>
          
        </MudGrid>
    </MudCardContent>
</MudCard>