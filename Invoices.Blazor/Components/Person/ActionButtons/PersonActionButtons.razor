@using Invoices.Blazor.Components.Person.ActionButtons
@inherits PersonActionButtonsBase

<div class="d-flex gap-2">
    @if (ShowDetail)
    {
        <ActionButton Icon="@Icons.Material.Filled.Visibility"
                      Tooltip="@T("DetailTooltip")"
                      OnClick="() => OnDetail.InvokeAsync(PersonModel)">
            @T("Detail")
        </ActionButton>
    }

    <ActionButton Icon="@Icons.Material.Filled.Edit"
                  Tooltip="@T("EditTooltip")"
                  OnClick="() => OnEdit.InvokeAsync(PersonModel)">
        @T("Edit")
    </ActionButton>

    <ActionButton Icon="@Icons.Material.Filled.Delete"
                  Color="Color.Error"
                  Tooltip="@T("DeleteTooltip")"
                  OnClick="() => OnDelete.InvokeAsync(PersonModel)">
        @T("Delete")
    </ActionButton>
</div>
