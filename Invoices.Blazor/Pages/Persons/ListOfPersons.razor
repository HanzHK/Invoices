@using Invoices.Blazor.Components.Infrastructure.Localization
@using Invoices.Blazor.Components.Person.List
@inherits LocalizationPageBase
@page "/subjects/list"

<MudPaper Class="pa-16 ma-8">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
        <MudText Typo="Typo.h5">@T("PersonListTitle")</MudText>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Add"
                   Href="/subjects/add">
            @T("AddPerson")
        </MudButton>
    </MudStack>
    <PersonList Items="persons" />
</MudPaper>