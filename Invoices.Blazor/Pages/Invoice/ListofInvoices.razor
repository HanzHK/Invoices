@using Invoices.Blazor.Components.Infrastructure.Localization
@using Invoices.Blazor.Components.Invoice.List
@inherits LocalizationPageBase
@page "/invoices/list"

<MudPaper Class="pa-16 ma-8">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
        <MudText Typo="Typo.h5">@T("InvoiceListTitle")</MudText>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Add"
                   Href="/invoices/add">
            @T("AddInvoice")
        </MudButton>
    </MudStack>
    <InvoiceList Items="invoices" />
</MudPaper>
